{
  "name": "maides-v2",
  "version": "0.1.0",
  "private": true,
  "description": "Reconstruction moderne (TypeScript) du constructeur d'applications de gestion « maides ».",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
